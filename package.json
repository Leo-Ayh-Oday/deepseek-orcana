{
  "name": "deepseek-orcana",
  "version": "0.2.0",
  "description": "Terminal coding agent with model-backed runtime, TUI, and workflow gates.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leo-Ayh-Oday/deepseek-orcana.git"
  },
  "bugs": {
    "url": "https://github.com/Leo-Ayh-Oday/deepseek-orcana/issues"
  },
  "homepage": "https://github.com/Leo-Ayh-Oday/deepseek-orcana#readme",
  "keywords": [
    "deepseek",
    "coding-agent",
    "terminal-ai",
    "bun",
    "typescript"
  ],
  "main": "dist/src/index.js",
  "bin": {
    "orcana": "bin/deepseek-code.cjs",
    "deepseek-orcana": "bin/deepseek-code.cjs",
    "deepseek-code": "bin/deepseek-code.cjs",
    "deepseek": "bin/deepseek-code.cjs"
  },
  "files": [
    "bin/",
    "dist/src/",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "clean": "node scripts/clean-dist.cjs",
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "test": "node scripts/run-tests.cjs",
    "test:all": "bun test",
    "test:integration": "bun test tests/agent_loop.test.ts tests/e2e_fullstack_flow.test.ts tests/e2e_user_flow.test.ts tests/thinking_depth.test.ts tests/thinking_quality.test.ts",
    "test:live": "bun test tests/code_as_action.test.ts tests/fullstack_depth.test.ts tests/knowledge_pipeline.test.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "test:watch": "node scripts/run-tests.cjs --watch"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@clack/prompts": "^1.5.1",
    "@inkjs/ui": "^2.0.0",
    "@json-render/core": "^0.19.0",
    "@json-render/ink": "^0.19.0",
    "@types/react": "^19.2.17",
    "boxen": "^8.0.1",
    "chalk": "^5.4.0",
    "figlet": "^1.11.0",
    "hono": "^4.12.25",
    "ink": "^7.0.6",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^8.2.0",
    "react": "^19.2.7",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
