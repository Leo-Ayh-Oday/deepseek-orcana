# DeepSeek Orcana environment
# Copy this file to .env in the project where you run Orcana.

# Required for the default DeepSeek provider.
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: DeepSeek Anthropic-compatible endpoint.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional: force a registered model id.
# DEEPSEEK_MODEL_OVERRIDE=deepseek-v4-pro

# Optional: set stricter cost behavior.
# DEEPSEEK_COST_MODE=normal

# Optional: tune long-context memory checkpointing.
# DEEPSEEK_M0_THRESHOLD_TOKENS=50000

# Optional: provider idle timeout in milliseconds.
# DEEPSEEK_PROVIDER_IDLE_TIMEOUT_MS=60000

# Optional: disable the TUI startup splash.
# DEEPSEEK_TUI_SPLASH=off
